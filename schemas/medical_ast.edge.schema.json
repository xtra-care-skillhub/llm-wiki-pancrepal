{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xtra-care-skillhub.org/schemas/medical_ast.edge.schema.json",
  "title": "MedicalASTEdge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "edge_id",
    "edge_type",
    "from_node_id",
    "to_node_id",
    "provenance",
    "source_id",
    "evidence_span"
  ],
  "properties": {
    "edge_id": {
      "type": "string",
      "minLength": 1
    },
    "edge_type": {
      "type": "string",
      "enum": [
        "has_demographics",
        "has_diagnosis",
        "has_stage",
        "has_biomarker",
        "received_treatment",
        "includes_medication",
        "developed_adverse_event",
        "has_follow_up",
        "has_recurrence",
        "has_metastasis",
        "has_outcome",
        "supported_by_source",
        "contradicts",
        "related_to"
      ]
    },
    "from_node_id": {
      "type": "string",
      "minLength": 1
    },
    "to_node_id": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "provenance": {
      "type": "string",
      "enum": [
        "extracted",
        "inferred",
        "ambiguous"
      ]
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_span": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "locator"
      ],
      "properties": {
        "locator": {
          "type": "string"
        },
        "quote": {
          "type": "string"
        },
        "offset_start": {
          "type": "integer",
          "minimum": 0
        },
        "offset_end": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "source_authority": {
      "type": "string"
    },
    "evidence_grade": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xtra-care-skillhub.org/schemas/medical_ast.snapshot.schema.json",
  "title": "MedicalASTSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshot_id",
    "generated_at",
    "version",
    "nodes",
    "edges"
  ],
  "properties": {
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "description": "如 pdac / rare-disease / chronic-disease"
    },
    "source_manifest_hash": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "./medical_ast.node.schema.json"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "./medical_ast.edge.schema.json"
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "node_count": {
          "type": "integer",
          "minimum": 0
        },
        "edge_count": {
          "type": "integer",
          "minimum": 0
        },
        "orphan_node_count": {
          "type": "integer",
          "minimum": 0
        },
        "ambiguous_edge_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
